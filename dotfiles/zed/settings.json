// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    // editor
    "terminal": {
        "font_size": 15.0,
    },
    "base_keymap": "JetBrains",
    "theme": {
        "mode": "dark",
        "light": "Ayu Light",
        "dark": "Rainbow (Dark)",
    },
    "ui_font_size": 18.0,
    "buffer_font_size": 18.0,
    "autosave": "on_focus_change",
    "project_panel": {
        "button": true,
        "default_width": 240,
        /* This controls the horizontal indentation of folders */
        "indent_size": 30,
        /* Use "compact" for more items or "comfortable" for more padding */
        // "entry_spacing": "comfortable",
        "git_status": true,
        "dock": "right",
    },
    "hard_tabs": false,
    "tab_size": 4,

    // git
    "git_panel": {
        "tree_view": true,
        "dock": "left",
    },

    "show_whitespaces": "none",
    "which_key": {
        "delay_ms": 200,
        "enabled": true,
    },

    // helix
    "helix_mode": true,

    // vim
    "vim_mode": true,

    "auto_signature_help": false,

    "context_servers": {
        "memory": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-memory"],
        },
        "git": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-git"],
        },
    },

    "agent": {
        "tool_permissions": {
            "default": "allow",
            "tools": {
                "terminal": {
                    "default": "allow",
                },
            },
        },
        "default_model": {
            "provider": "google",
            "model": "gemini-1.5-pro",
        },
        "commit_message_model": {
            "provider": "google",
            "model": "gemini-1.5-pro",
        },
    },
    "experimental.theme_overrides": {
        "editor.active_line.background": "#ADECE415",
    },
}
